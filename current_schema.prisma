generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isRead    Boolean   @default(false)
  readAt    DateTime?

  @@index([email])
  @@index([createdAt])
  @@index([isRead])
  @@index([isRead, createdAt])
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model DevsDayRegistration {
  id          String   @id @default(uuid())
  name        String
  email       String
  role        String
  stack       String?
  expectation String?
  profile     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model Event {
  id            String              @id @default(uuid())
  title         String
  slug          String              @unique
  description   String
  dateTime      DateTime
  location      String
  imagePublicId String?
  attendeeLimit Int?
  status        EventStatus         @default(DRAFT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  timezone      String              @default("Africa/Lagos")
  formFields    EventFormField[]
  registrations EventRegistration[]

  @@index([slug])
  @@index([status])
  @@index([dateTime])
  @@index([createdAt])
}

model EventFormField {
  id          String        @id @default(uuid())
  eventId     String
  name        String
  label       String
  type        FormFieldType @default(TEXT)
  placeholder String?
  required    Boolean       @default(false)
  options     String?
  position    Int           @default(0)
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
  @@index([eventId])
}

model EventRegistration {
  id            String             @id @default(uuid())
  eventId       String
  email         String
  name          String
  status        RegistrationStatus @default(PENDING)
  declineReason String?
  formData      String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([eventId, status])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model ServiceContent {
  id                      String      @id @default(uuid())
  type                    ServiceType @unique
  title                   String
  description             String
  updatedAt               DateTime    @updatedAt
  backgroundImagePublicId String?
  cardColor               String      @default("#000c99")
  iconPublicId            String?
  overlayColor            String      @default("#000c99")
  portfolioDescription    String      @default("")
  portfolioEyebrow        String      @default("")

  @@index([type])
}

model ProjectsHeroContent {
  id                      Int      @id @default(autoincrement())
  eyebrow                 String   @default("Portfolio selection")
  headline                String   @default("Work that looks sharp, moves with intent, and lands where it matters.")
  body                    String   @default("Explore selected projects across design, build, and print — all curated to show how ideas become real, useful, and memorable.")
  backgroundImagePublicId String?
  ctaText                 String   @default("Start a Project")
  ctaHref                 String   @default("/contact")
  updatedAt               DateTime @updatedAt
  cta2Href                String   @default("/#services")
  cta2Text                String   @default("Explore Services")
  ctaSectionBody          String   @default("We take ideas from early direction through execution, across digital, print, and the spaces in between.")
  ctaSectionHeadline      String   @default("If the work feels close to what you need, we should talk.")
  ctaSectionLabel         String   @default("Start something precise")
}

model PortfolioItem {
  id                String           @id @default(uuid())
  serviceType       ServiceType
  title             String
  description       String?
  tags              String           @default("[]")
  mediaPublicId     String
  mediaType         MediaType        @default(IMAGE)
  thumbnailPublicId String?
  isFeatured        Boolean          @default(false)
  isVisible         Boolean          @default(true)
  position          Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  clientName        String?
  coverAssetId      String?
  objectPosition    String           @default("center")
  slug              String?          @unique
  websiteUrl        String?
  assets            PortfolioAsset[] @relation("PortfolioItemAssets")
  coverAsset        PortfolioAsset?  @relation("PortfolioCoverAsset", fields: [coverAssetId], references: [id])

  @@index([serviceType])
  @@index([serviceType, isFeatured])
  @@index([serviceType, isVisible])
  @@index([position])
  @@index([slug])
}

model PortfolioAsset {
  id                String          @id @default(uuid())
  portfolioItemId   String
  publicId          String
  mediaType         MediaType       @default(IMAGE)
  thumbnailPublicId String?
  caption           String?
  position          Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  portfolioItem     PortfolioItem   @relation("PortfolioItemAssets", fields: [portfolioItemId], references: [id], onDelete: Cascade)
  coverForItems     PortfolioItem[] @relation("PortfolioCoverAsset")

  @@index([portfolioItemId])
  @@index([portfolioItemId, position])
}

model Expression {
  id           String   @id @default(uuid())
  name         String
  logoPublicId String?
  description  String
  websiteUrl   String
  position     Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([position])
  @@index([isVisible])
}

model ManifestoContent {
  id        Int      @id @default(autoincrement())
  text      String   @default("IF YOU'VE GOT A VISION, WE'VE GOT THE CREATIVE AUDACITY")
  updatedAt DateTime @updatedAt
}

model HeroContent {
  id                        Int      @id @default(autoincrement())
  backgroundImagePublicId   String?
  cardFallbackImagePublicId String?
  eyebrow                   String   @default("Dexta Synergy Services")
  headline                  String
  body                      String
  ctaText                   String   @default("See Our Work")
  ctaHref                   String   @default("/projects")
  stackBadge                String   @default("Dexta service stack")
  stackTitle                String
  stackBody                 String
  stackCtaText              String   @default("Start a Project")
  stackCtaHref              String   @default("/contact")
  updatedAt                 DateTime @updatedAt
}

model HeroCard {
  id             String   @id @default(uuid())
  position       Int      @default(0)
  href           String
  imagePublicId  String?
  objectPosition String   @default("center")
  label          String
  title          String
  chip           String
  badge          String
  metaTitle      String
  metaSubtitle   String
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([position])
}

model OffersPageContent {
  id                          Int      @id @default(autoincrement())
  heroEyebrow                 String   @default("What We Offer")
  heroHeadline                String   @default("Reach More. Build More. Stay Visible.")
  heroBody                    String   @default("From bold brand identities to high-performing websites and targeted mass communication — Dexta brings creative precision to every touchpoint.")
  heroBgImagePublicId         String?
  heroCtaText                 String   @default("Explore Plans")
  heroCtaHref                 String   @default("#pricing")
  servicesSectionLabel        String   @default("Our Capabilities")
  servicesSectionTitle        String   @default("Three disciplines. One studio.")
  servicesSectionBody         String   @default("We operate across design, digital engineering, and print — bringing every service under one roof so your brand stays consistent no matter the format.")
  audienceSectionLabel        String   @default("Who We Serve")
  audienceSectionTitle        String   @default("Packages tailored to how you operate.")
  audienceSectionBody         String   @default("Whether you're scaling a business, building a school's reputation, or growing a faith community — we have a plan designed specifically for your context.")
  reachPlansTitle             String   @default("Reach Plans")
  reachPlansDescription       String   @default("Switch between monthly and quarterly billing to compare ongoing visibility support.")
  setupPlansTitle             String   @default("Setup Plans")
  setupPlansDescription       String   @default("Review one-time setup packages for launch, structure, and polish.")
  billingLabel                String   @default("Billing")
  billingMonthlyLabel         String   @default("Monthly")
  billingMonthlyDescription   String   @default("Pay monthly for flexible support.")
  billingQuarterlyLabel       String   @default("Quarterly")
  billingQuarterlyDescription String   @default("Lower effective cost across 3 months.")
  popularBadgeText            String   @default("Popular Pick")
  reachBadgeLabel             String   @default("Reach")
  featuresLabel               String   @default("Includes")
  choosePlanText              String   @default("Choose Plan")
  requestQuoteText            String   @default("Request Quote")
  ctaLabel                    String   @default("Ready to get started?")
  ctaTitle                    String   @default("Your next move starts here.")
  ctaBody                     String   @default("Tell us where you are and where you want to go. We'll handle the rest.")
  cta1Text                    String   @default("Get a Quote")
  cta1Href                    String   @default("/contact")
  cta2Text                    String   @default("View Our Work")
  cta2Href                    String   @default("/projects")
  updatedAt                   DateTime @updatedAt
}

model Audience {
  id               String        @id @default(uuid())
  type             AudienceType  @unique
  tabLabel         String        @default("")
  title            String
  subtitle         String
  description      String
  pathLabel        String        @default("")
  spotlight        String        @default("")
  focusAreas       String        @default("[]")
  plansTitle       String        @default("")
  plansDescription String        @default("")
  emptyTitle       String        @default("")
  emptyBody        String        @default("")
  color            String        @default("cyan")
  isVisible        Boolean       @default(true)
  updatedAt        DateTime      @updatedAt
  plans            PricingPlan[]

  @@index([type])
}

model PricingPlan {
  id                String       @id @default(uuid())
  audienceType      AudienceType
  planType          PlanType
  name              String
  subtitle          String?
  priceMonthlyUSD   Float?
  priceQuarterlyUSD Float?
  priceMonthlyNGN   Float?
  priceQuarterlyNGN Float?
  reachCount        Int?
  features          String       @default("[]")
  isHighlighted     Boolean      @default(false)
  isVisible         Boolean      @default(true)
  position          Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  audience          Audience     @relation(fields: [audienceType], references: [type], onDelete: Cascade)

  @@index([audienceType])
  @@index([audienceType, planType])
  @@index([audienceType, planType, position])
}

model ContactPageContent {
  id           Int      @id @default(autoincrement())
  homeEyebrow  String   @default("Get in touch")
  homeTitle    String   @default("Let's Work Together")
  homeBody     String   @default("Ready to start a project or just have a question? We'd love to hear from you.")
  homeCtaText  String   @default("Contact Us")
  homeCtaHref  String   @default("/contact")
  heroEyebrow  String   @default("Contact Us")
  heroTitle    String   @default("Get In Touch")
  heroBody     String   @default("Have a project in mind? Let's bring your vision to life. Reach out and we'll get back to you shortly.")
  infoEyebrow  String   @default("Where to find us")
  infoTitle    String   @default("Contact Information")
  infoBody     String   @default("We're based in Port Harcourt, Nigeria and work with clients across the globe.")
  formEyebrow  String   @default("Send a message")
  formTitle    String   @default("Drop Us a Line")
  formBody     String   @default("Fill in the form and we'll respond within one business day.")
  addressLabel String   @default("Address")
  address      String   @default("96 Elioparanwo Road, Port Harcourt, Rivers State, Nigeria")
  emailLabel   String   @default("Email")
  emails       String   @default("[\"info@dexta.services\",\"admin@dexta.services\"]")
  phoneLabel   String   @default("Phone")
  phones       String   @default("[\"+234 810 320 8287\"]")
  socialsLabel String   @default("Follow Us")
  updatedAt    DateTime @updatedAt
}

model ContactSocialLink {
  id        String                @id @default(uuid())
  platform  ContactSocialPlatform @unique
  label     String
  href      String
  isVisible Boolean               @default(true)
  position  Int                   @default(0)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutPageContent {
  id                          Int      @id @default(autoincrement())
  heroEyebrow                 String   @default("About Dexta")
  heroHeadline                String   @default("Built to shape brands, products, and public presence with clarity.")
  heroBody                    String   @default("We are a design-led digital studio helping ambitious teams communicate better, launch stronger, and grow with confidence.")
  heroBackgroundImagePublicId String?
  heroPrimaryCtaText          String   @default("Start a Project")
  heroPrimaryCtaHref          String   @default("/contact")
  heroSecondaryCtaText        String   @default("View Our Work")
  heroSecondaryCtaHref        String   @default("/projects")
  heroStat1Value              String   @default("6+")
  heroStat1Label              String   @default("Years of momentum")
  heroStat2Value              String   @default("200+")
  heroStat2Label              String   @default("Projects delivered")
  heroStat3Value              String   @default("98%")
  heroStat3Label              String   @default("Client retention")
  heroStat4Value              String   @default("50+")
  heroStat4Label              String   @default("Teams supported")
  storyLabel                  String   @default("Our Story")
  storyTitle                  String   @default("A modern studio built on precision, partnership, and momentum.")
  storyBody1                  String   @default("Dexta began with a simple conviction: brands and organisations deserve sharper thinking, stronger execution, and digital work that actually moves the needle.")
  storyBody2                  String   @default("Today, we help businesses, schools, and institutions translate ambition into clear brand systems, reliable digital products, and public-facing experiences people trust.")
  storyHighlightTitle         String   @default("Trusted across fast-moving sectors")
  storyHighlightBody          String   @default("We bring design discipline, technical execution, and practical business thinking to every engagement.")
  storyTrustedLabel           String   @default("We work across")
  storyTrustedItems           String   @default("[\"Fintech\",\"Education\",\"Healthcare\",\"Commerce\"]")
  expertiseLabel              String   @default("What We Bring")
  expertiseTitle              String   @default("Strategy, design, and delivery aligned in one system.")
  expertiseBody               String   @default("Our expertise sits at the intersection of brand thinking, product execution, and real-world communication support.")
  teamLabel                   String   @default("Our Team")
  teamTitle                   String   @default("The people shaping the work behind the scenes.")
  teamBody                    String   @default("Our team blends creative direction, technical depth, and thoughtful execution across every client touchpoint.")
  cultureTitle                String   @default("How We Work")
  cultureBody                 String   @default("We care about thoughtful collaboration, clear communication, and building work that feels sharp, useful, and durable.")
  valuesLabel                 String   @default("Our Values")
  valuesTitle                 String   @default("The standards we bring into every engagement.")
  valuesBody                  String   @default("These values shape how we think, how we build, and how we partner with the teams we support.")
  ctaLabel                    String   @default("Let’s build something clear and ambitious.")
  ctaTitle                    String   @default("If the way we think feels like a fit, we should talk.")
  ctaBody                     String   @default("Tell us what you’re building and we’ll help shape the right brand, digital, and communication direction for it.")
  ctaText                     String   @default("Start a Conversation")
  ctaHref                     String   @default("/contact")
  updatedAt                   DateTime @updatedAt
}

model AboutMilestone {
  id          String   @id @default(uuid())
  year        String
  title       String
  description String
  isVisible   Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutExpertiseItem {
  id          String       @id @default(uuid())
  icon        AboutIconKey
  title       String
  description String
  metricLabel String
  metricValue String
  isVisible   Boolean      @default(true)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutTeamMember {
  id            String   @id @default(uuid())
  name          String
  role          String
  bio           String
  expertise     String   @default("[]")
  funFact       String
  portfolioUrl  String
  imagePublicId String?
  isVisible     Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutValueItem {
  id          String       @id @default(uuid())
  icon        AboutIconKey
  title       String
  description String
  isVisible   Boolean      @default(true)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([position])
  @@index([isVisible])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FormFieldType {
  TEXT
  EMAIL
  SELECT
  TEXTAREA
  URL
  CHECKBOX
}

enum ServiceType {
  DESIGN
  BUILD
  PRINT
}

enum MediaType {
  IMAGE
  VIDEO
}

enum AudienceType {
  BUSINESS
  SCHOOLS
  CHURCHES
}

enum PlanType {
  REACH
  SETUP
}

enum ContactSocialPlatform {
  LINKEDIN
  INSTAGRAM
  X
  FACEBOOK
  WHATSAPP
  YOUTUBE
  TIKTOK
}

enum AboutIconKey {
  ZAP
  GLOBE
  SPARKLES
  TRENDING_UP
  TARGET
  LIGHTBULB
  HEART_HANDSHAKE
  SHIELD
}



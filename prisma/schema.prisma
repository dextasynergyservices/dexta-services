}

model AboutTeamMember {
  id                  String   @id @default(uuid())
  name                String
  role                String
  bio                 String
  expertise           String   @default("[]")
  funFact             String
  portfolioUrl        String
  showPortfolioButton Boolean  @default(true)
  imagePublicId       String?
  isVisible           Boolean  @default(true)
  position            Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutSpaceItem {
  id                String    @id @default(uuid())
  title             String
  description       String
  mediaType         MediaType @default(IMAGE)
  mediaPublicId     String?
  thumbnailPublicId String?
  isVisible         Boolean   @default(true)
  position          Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([position])
  @@index([isVisible])
}

model AboutValueItem {
  id          String       @id @default(uuid())
  icon        AboutIconKey
  title       String
  description String
  isVisible   Boolean      @default(true)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([position])
  @@index([isVisible])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([createdAt])
  @@index([isRead])
  @@index([isRead, createdAt])
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// @deprecated — migrated to Event + EventRegistration
model DevsDayRegistration {
  id          String   @id @default(uuid())
  name        String
  email       String
  role        String
  stack       String? // optional tech stack
  expectation String? // optional what they're looking forward to
  profile     String? // optional URL (GitHub/LinkedIn)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

// --- Event Management ---

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FormFieldType {
  TEXT
  EMAIL
  SELECT
  TEXTAREA
  URL
  CHECKBOX
}

model Event {
  id            String      @id @default(uuid())
  title         String
  slug          String      @unique
  description   String
  dateTime      DateTime
  timezone      String      @default("Africa/Lagos")
  location      String
  imagePublicId String? // Cloudinary public ID
  attendeeLimit Int? // null = unlimited
  status        EventStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  formFields    EventFormField[]
  registrations EventRegistration[]

  @@index([slug])
  @@index([status])
  @@index([dateTime])
  @@index([createdAt])
}

model EventFormField {
  id          String        @id @default(uuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String // machine key e.g. "tech_stack"
  label       String // display e.g. "Tech Stack"
  type        FormFieldType @default(TEXT)
  placeholder String?
  required    Boolean       @default(false)
  options     String? // JSON array for SELECT, e.g. '["A","B"]'
  position    Int           @default(0)

  @@unique([eventId, name])
  @@index([eventId])
}

model EventRegistration {
  id            String             @id @default(uuid())
  eventId       String
  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email         String
  name          String
  status        RegistrationStatus @default(PENDING)
  declineReason String?
  formData      String // JSON of field responses keyed by field name
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([eventId, email])
  @@index([eventId])
  @@index([eventId, status])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// --- Portfolio & Services ---

enum ServiceType {
  DESIGN
  BUILD
  PRINT
}

enum MediaType {
  IMAGE
  VIDEO
}

// One row per service type — stores editable landing page copy
model ServiceContent {
  id                      String      @id @default(uuid())
  type                    ServiceType @unique
  title                   String
  description             String
  iconPublicId            String?
  cardColor               String      @default("#000c99")
  overlayColor            String      @default("#000c99")
  backgroundImagePublicId String?
  // Portfolio page tab-specific copy
  portfolioEyebrow        String      @default("")
  portfolioDescription    String      @default("")
  updatedAt               DateTime    @updatedAt

  @@index([type])
}

// Singleton — always one row (id = 1). Stores hero copy and media for /projects.
model ProjectsHeroContent {
  id                      Int      @id @default(autoincrement())
  eyebrow                 String   @default("Portfolio selection")
  headline                String   @default("Work that looks sharp, moves with intent, and lands where it matters.")
  body                    String   @default("Explore selected projects across design, build, and print — all curated to show how ideas become real, useful, and memorable.")
  backgroundImagePublicId String?
  ctaText                 String   @default("Start a Project")
  ctaHref                 String   @default("/contact")
  // Bottom CTA section copy
  ctaSectionLabel         String   @default("Start something precise")
  ctaSectionHeadline      String   @default("If the work feels close to what you need, we should talk.")
  ctaSectionBody          String   @default("We take ideas from early direction through execution, across digital, print, and the spaces in between.")
  cta2Text                String   @default("Explore Services")
  cta2Href                String   @default("/#services")
  updatedAt               DateTime @updatedAt
}

// One row per project — shared between homepage feature rotation + /projects page.
// The legacy single-media fields remain during the transition to gallery-based assets.
model PortfolioItem {
  id                String           @id @default(uuid())
  serviceType       ServiceType
  title             String
  description       String?
  clientName        String?
  slug              String?          @unique
  tags              String           @default("[]") // JSON array string e.g. '["Logo","Branding"]'
  websiteUrl        String?
  objectPosition    String           @default("center")
  mediaPublicId     String // legacy primary media field kept for compatibility during migration
  mediaType         MediaType        @default(IMAGE)
  thumbnailPublicId String? // legacy video poster frame kept for compatibility during migration
  coverAssetId      String?
  coverAsset        PortfolioAsset?  @relation("PortfolioCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  assets            PortfolioAsset[] @relation("PortfolioItemAssets")
  isFeatured        Boolean          @default(false) // Rotates on landing page service card
  isVisible         Boolean          @default(true) // Controls visibility on /projects page
  position          Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([serviceType])
  @@index([serviceType, isFeatured])
  @@index([serviceType, isVisible])
  @@index([position])
  @@index([slug])
}

model PortfolioAsset {
  id                String          @id @default(uuid())
  portfolioItemId   String
  portfolioItem     PortfolioItem   @relation("PortfolioItemAssets", fields: [portfolioItemId], references: [id], onDelete: Cascade)
  publicId          String
  mediaType         MediaType       @default(IMAGE)
  thumbnailPublicId String?
  caption           String?
  position          Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  coverForItems     PortfolioItem[] @relation("PortfolioCoverAsset")

  @@index([portfolioItemId])
  @@index([portfolioItemId, position])
}

// --- Expressions Section ---

model Expression {
  id           String   @id @default(uuid())
  name         String
  logoPublicId String?
  description  String
  websiteUrl   String
  position     Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([position])
  @@index([isVisible])
}

// --- Manifesto Section ---

// Singleton — always one row (id = 1). Stores the scroll-reveal brand statement.
model ManifestoContent {
  id        Int      @id @default(autoincrement())
  text      String   @default("IF YOU'VE GOT A VISION, WE'VE GOT THE CREATIVE AUDACITY")
  updatedAt DateTime @updatedAt
}

// --- Hero Content ---

// Singleton — always one row (id = 1). Manages both hero copy zones and images.
model HeroContent {
  id Int @id @default(autoincrement())

  // Images
  backgroundImagePublicId   String? // Cloudinary public ID for the full-bleed background
  cardFallbackImagePublicId String? // Cloudinary public ID used as fallback for cards with no individual image

  // Zone 1: Main hero copy
  eyebrow  String @default("Dexta Synergy Services")
  headline String
  body     String
  ctaText  String @default("See Our Work")
  ctaHref  String @default("/projects")

  // Zone 2: Service stack section (post-scroll)
  stackBadge   String @default("Dexta service stack")
  stackTitle   String
  stackBody    String
  stackCtaText String @default("Start a Project")
  stackCtaHref String @default("/contact")

  updatedAt DateTime @updatedAt
}

// Ordered list of hero cards — replaces the hardcoded HERO_CARDS object.
model HeroCard {
  id             String   @id @default(uuid())
  position       Int      @default(0) // 0=left, 1=center, 2=right
  href           String
  imagePublicId  String? // Cloudinary public ID; null = use local fallback
  objectPosition String   @default("center")
  label          String // e.g. "IDENTITY"
  title          String // e.g. "DESIGN"
  chip           String // e.g. "Brand systems"
  badge          String // e.g. "ID"
  metaTitle      String
  metaSubtitle   String
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([position])
}

// --- Offers Page ---

enum AudienceType {
  FOR_YOU
  BUSINESS
  SCHOOLS
  CHURCHES
}

enum BillingDuration {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ContactSocialPlatform {
  LINKEDIN
  INSTAGRAM
  X
  FACEBOOK
  WHATSAPP
  YOUTUBE
  TIKTOK
}

enum SchoolWebsiteJobStatus {
  PENDING
  IN_PROGRESS
  LIVE
  DECLINED
}

enum SchoolWebsiteDomainChoice {
  HAS_DOMAIN
  NEEDS_DOMAIN
}

enum AboutIconKey {
  ZAP
  GLOBE
  SPARKLES
  TRENDING_UP
  TARGET
  LIGHTBULB
  HEART_HANDSHAKE
  SHIELD
}

// Singleton — always one row (id = 1). All copy for the /offers page.
model OffersPageContent {
  id                   Int      @id @default(autoincrement())
  // Hero
  heroEyebrow          String   @default("What We Offer")
  heroHeadline         String   @default("Reach More. Build More. Stay Visible.")
  heroBody             String   @default("From bold brand identities to high-performing websites and targeted mass communication — Dexta brings creative precision to every touchpoint.")
  heroBgImagePublicId  String?
  heroCtaText          String   @default("Explore Offers")
  heroCtaHref          String   @default("#pricing")
  // "What We Do" services section
  servicesSectionLabel String   @default("What We Do")
  servicesSectionTitle String   @default("Design, build, and print under one clear direction.")
  servicesSectionBody  String   @default("From visual identity to digital delivery and print production, Dexta helps teams show up clearly across every channel.")
  // "Who We Serve" audience section
  audienceSectionLabel String   @default("Who We Serve")
  audienceSectionTitle String   @default("Packages tailored to how you operate.")
  audienceSectionBody  String   @default("Whether you're scaling a business, building a school's reputation, or growing a faith community — we have an offer designed specifically for your context.")
  // Offer card UI copy
  popularBadgeText     String   @default("Popular Pick")
  featuresLabel        String   @default("Includes")
  choosePlanText       String   @default("Choose Offer")
  requestQuoteText     String   @default("Request Quote")
  // Bottom CTA
  ctaLabel             String   @default("Ready to get started?")
  ctaTitle             String   @default("Your next move starts here.")
  ctaBody              String   @default("Tell us where you are and where you want to go. We'll handle the rest.")
  cta1Text             String   @default("Get a Quote")
  cta1Href             String   @default("/contact")
  cta2Text             String   @default("View Our Work")
  cta2Href             String   @default("/projects")
  updatedAt            DateTime @updatedAt
}

// One row per audience type — label, color, visibility
model Audience {
  id          String       @id @default(uuid())
  type        AudienceType @unique
  tabLabel    String       @default("")
  emptyTitle  String       @default("")
  emptyBody   String       @default("")
  color       String       @default("cyan") // "cyan" | "blue" | "purple"
  isVisible   Boolean      @default(true)
  offerGroups OfferGroup[]
  updatedAt   DateTime     @updatedAt

  @@index([type])
}

// Offer group — a named collection of plans within one audience
// (e.g. "Mass SMS", "Website Packages", "Brand Identity")
model OfferGroup {
  id           String        @id @default(uuid())
  audienceType AudienceType
  audience     Audience      @relation(fields: [audienceType], references: [type], onDelete: Cascade)
  name         String
  description  String?
  position     Int           @default(0)
  isVisible    Boolean       @default(true)
  plans        PricingPlan[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([audienceType])
  @@index([audienceType, position])
}

// Individual pricing plan — belongs to one OfferGroup
model PricingPlan {
  id                 String              @id @default(uuid())
  offerGroupId       String
  offerGroup         OfferGroup          @relation(fields: [offerGroupId], references: [id], onDelete: Cascade)
  name               String
  subtitle           String?
  imagePublicId      String?
  features           String              @default("[]") // JSON array of feature strings
  billingEnabled     Boolean             @default(false) // admin toggle: show billing options inside card
  isHighlighted      Boolean             @default(false)
  highlightBgColor   String?
  highlightTextColor String?
  isVisible          Boolean             @default(true)
  position           Int                 @default(0)
  billingOptions     PlanBillingOption[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([offerGroupId])
  @@index([offerGroupId, position])
}

// One row per billing duration per plan — admin creates these to offer pricing tiers
model PlanBillingOption {
  id        String          @id @default(uuid())
  planId    String
  plan      PricingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  duration  BillingDuration
  priceNGN  Float?
  priceUSD  Float?
  label     String? // optional display override e.g. "₦5,000 / month"
  isDefault Boolean         @default(false) // which option is pre-selected in the card
  position  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([planId, duration])
  @@index([planId])
  @@index([planId, position])
}

